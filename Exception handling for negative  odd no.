#include<iostream>
#include<cmath>
using namespace std;
class Odd
{
    public:
    const char*show()
    {
       return "Cannot handle negative  even no";
    }
};
int main()
{
    cout<<" enter";
    int n,i;
    int a[n];
    try
    {
        for(i=0;i<n;i++)
        {
            cin>>a[i];
        }
        if(n<0 || n%2==0)
        {
            throw Odd();
        }
        cout<<"odd";
}
catch(Odd &o)
{
    cout<<o.show();
}}
